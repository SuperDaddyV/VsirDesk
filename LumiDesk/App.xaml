<Application x:Class="LumiDesk.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LumiDesk"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes/Shared.xaml"/>
                <ResourceDictionary Source="Resources/Themes/Dark.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="QWeatherIconsFont">pack://application:,,,/icon/QWeather-Icons-1.8.0/font/fonts/#qweather-icons</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>