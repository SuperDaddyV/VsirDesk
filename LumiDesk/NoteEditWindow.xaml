<Window x:Class="LumiDesk.NoteEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="420"
        Width="360"
        MinHeight="320"
        MinWidth="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        KeyDown="NoteEditWindow_OnKeyDown">

    <Border CornerRadius="8"
            Background="#EAFBE8"
            BorderBrush="#CFE7CA"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="18,12"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="源:"
                                   FontSize="15"
                                   Foreground="#69756F"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Border Background="#CFEBC8"
                                CornerRadius="18"
                                Padding="9,5">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22"
                                        CornerRadius="11"
                                        Background="#7668FF"
                                        Margin="0,0,7,0">
                                    <TextBlock Text="✦"
                                               Foreground="White"
                                               FontSize="13"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="LumiDesk"
                                           FontSize="15"
                                           Foreground="#69756F"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="×"
                                           FontSize="18"
                                           Foreground="#69756F"
                                           Margin="10,-1,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource HeaderIconButtonStyle}"
                                Foreground="#59645E"
                                Click="MinimizeButton_OnClick"
                                ToolTip="最小化">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                        <Button Style="{StaticResource HeaderIconButtonStyle}"
                                Foreground="#59645E"
                                Click="CloseButton_OnClick"
                                ToolTip="关闭">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="26,10,26,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0"
                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="#4B5852"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         Margin="0,0,0,14"/>

                <TextBox Grid.Row="1"
                         Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="20"
                         Foreground="#7B8781"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         CaretBrush="#5E6B64"/>
            </Grid>

            <Grid Grid.Row="2" Margin="22,16,22,18">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            Foreground="#59645E"
                            ToolTip="更多">
                        <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                    </Button>
                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                            Foreground="#59645E"
                            ToolTip="弹出">
                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消"
                            Width="72"
                            Height="34"
                            Margin="0,0,8,0"
                            Background="#DCEBDA"
                            Foreground="#4F5C55"
                            BorderThickness="0"
                            Click="CancelButton_OnClick"/>
                    <Button Content="保存"
                            Width="72"
                            Height="34"
                            IsDefault="True"
                            Background="#B7E1AE"
                            Foreground="#33443A"
                            BorderThickness="0"
                            Click="SaveButton_OnClick"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
