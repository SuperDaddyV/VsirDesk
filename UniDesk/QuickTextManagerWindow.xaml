<Window x:Class="UniDesk.QuickTextManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Height="520"
        MinHeight="460"
        KeyDown="QuickTextManagerWindow_OnKeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="DlgBackground" Color="#E6FFFFFF"/>
        <SolidColorBrush x:Key="DlgTextPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="DlgTextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="DlgBorder" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="DlgInputBackground" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="DlgAccent" Color="#3B82F6"/>
        <SolidColorBrush x:Key="DlgAccentSoft" Color="#1A3B82F6"/>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="DlgButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Background" Value="{StaticResource DlgInputBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="10,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="DialogRoot"
            Background="{StaticResource DlgBackground}"
            BorderBrush="{StaticResource DlgBorder}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="4"
            MouseLeftButtonDown="DialogRoot_OnMouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="14,12,12,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="24" Height="24" CornerRadius="6" Background="{StaticResource DlgAccent}" Margin="0,0,8,0">
                        <TextBlock Text="&#xE8C8;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="#0D2744"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="快捷文本管理"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource DlgTextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Width="28"
                        Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseButton_OnClick">
                    <TextBlock Text="&#xE711;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="11"
                               Foreground="{StaticResource DlgTextSecondary}"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="14,0,14,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="历史"
                            Margin="0,0,5,0"
                            Command="{Binding SelectModeCommand}"
                            CommandParameter="History">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DlgButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHistorySelected}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource DlgAccentSoft}"/>
                                        <Setter Property="Foreground" Value="{StaticResource DlgAccent}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Grid.Column="1"
                            Content="常用"
                            Margin="5,0,0,0"
                            Command="{Binding SelectModeCommand}"
                            CommandParameter="Snippets">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DlgButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSnippetsSelected}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource DlgAccentSoft}"/>
                                        <Setter Property="Foreground" Value="{StaticResource DlgAccent}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="88"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="30"
                             FontSize="12"
                             Foreground="{StaticResource DlgTextPrimary}"
                             Background="{StaticResource DlgInputBackground}"
                             BorderBrush="{StaticResource DlgBorder}"
                             BorderThickness="1"
                             Padding="9,5"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              Height="30"
                              FontSize="12"
                              Margin="8,0,0,0"
                              Visibility="{Binding IsSnippetsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="2" Margin="14,0,14,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsHistorySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding ClipboardHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource DlgInputBackground}"
                                        BorderBrush="{StaticResource DlgBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="9,7"
                                        Margin="0,0,0,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Summary}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource DlgTextPrimary}"
                                                   TextWrapping="Wrap"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                            <Button Style="{StaticResource DlgButton}" Content="复制" Command="{Binding DataContext.CopyHistoryCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource DlgButton}" Content="收藏" Margin="6,0,0,0" Command="{Binding DataContext.FavoriteHistoryCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource DlgButton}" Content="删除" Margin="6,0,0,0" Command="{Binding DataContext.DeleteHistoryCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsSnippetsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding TextSnippets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource DlgInputBackground}"
                                        BorderBrush="{StaticResource DlgBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="9,7"
                                        Margin="0,0,0,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayTitle}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DlgTextPrimary}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Summary}" FontSize="11" Foreground="{StaticResource DlgTextSecondary}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                            <Button Style="{StaticResource DlgButton}" Content="复制" Command="{Binding DataContext.CopySnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource DlgButton}" Content="编辑" Margin="6,0,0,0" Command="{Binding DataContext.EditSnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                            <Button Style="{StaticResource DlgButton}" Content="删除" Margin="6,0,0,0" Command="{Binding DataContext.DeleteSnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="3"
                    BorderBrush="{StaticResource DlgBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="14,10">
                <Grid>
                    <Button Style="{StaticResource DlgButton}"
                            Content="清空历史"
                            HorizontalAlignment="Left"
                            Command="{Binding ClearHistoryCommand}"
                            Visibility="{Binding IsHistorySelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Style="{StaticResource DlgButton}"
                            Content="新增短语"
                            HorizontalAlignment="Left"
                            Command="{Binding NewSnippetCommand}"
                            Visibility="{Binding IsSnippetsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Button Style="{StaticResource DlgButton}"
                            Content="关闭"
                            HorizontalAlignment="Right"
                            Click="CloseButton_OnClick"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
