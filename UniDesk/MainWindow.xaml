<Window x:Class="UniDesk.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:UniDesk.Helpers"
        xmlns:models="clr-namespace:UniDesk.Models"
        xmlns:controls="clr-namespace:UniDesk.Controls"
        mc:Ignorable="d"
        Title="{Binding DisplayTitle}"
        Height="{Binding PanelHeight}" Width="{Binding PanelWidth, Mode=TwoWay}"
        MinHeight="560" MaxHeight="920" MinWidth="320" MaxWidth="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="{Binding IsTopMost}"
        ResizeMode="NoResize"
        Loaded="MainWindow_OnLoaded"
        AllowDrop="True"
        PreviewDragEnter="Window_OnPreviewDragEnter"
        PreviewDragOver="Window_OnPreviewDragOver"
        PreviewDragLeave="Window_OnPreviewDragLeave"
        PreviewDrop="Window_OnPreviewDrop">

    <Window.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <helpers:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
        <helpers:TodoDueTextConverter x:Key="TodoDueTextConverter"/>
        <helpers:TodoDueIsTodayConverter x:Key="TodoDueIsTodayConverter"/>
        <helpers:ShortcutIconConverter x:Key="ShortcutIconConverter"/>
        <helpers:BundledIconPathConverter x:Key="BundledIconPathConverter"/>
        <helpers:TodoPriorityToBrushConverter x:Key="TodoPriorityBrush"/>
        <helpers:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <helpers:ScaledFontSizeConverter x:Key="ScaledFontSizeConverter"/>
        <Style x:Key="ModuleTitleIconBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        <Style x:Key="ModuleTitleIconFillStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        <Style x:Key="ModuleTitleIconPathStyle" TargetType="Path">
            <Setter Property="Stroke" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent"
          MouseLeftButtonDown="WindowDragSurface_OnMouseLeftButtonDown">
        <Border x:Name="WindowContainer"
                Style="{StaticResource GlassWindowBorderStyle}"
                ClipToBounds="True"
                Opacity="{Binding WindowOpacity}"
                SizeChanged="WindowContainer_OnSizeChanged">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="18,5,16,3"
                        MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="{Binding DisplayTitle}"
                                   FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=18}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource HeaderIconButtonStyle}"
                                    Width="24"
                                    Height="24"
                                    Command="{Binding ToggleTopMostCommand}"
                                    ToolTip="窗口置顶">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#xE718;"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTopMost}" Value="True">
                                                    <Setter Property="Text" Value="&#xE840;"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                            <Button Style="{StaticResource HeaderIconButtonStyle}"
                                    Width="24"
                                    Height="24"
                                    Command="{Binding ToggleWindowLockCommand}"
                                    ToolTip="{Binding WindowLockToolTip}">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#xE1F6;"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWindowLocked}" Value="False">
                                                    <Setter Property="Text" Value="&#xE1F7;"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                            <Button Style="{StaticResource HeaderIconButtonStyle}"
                                    Width="24"
                                    Height="24"
                                    Click="SettingsButton_OnClick"
                                    ToolTip="设置">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                            <Button Style="{StaticResource HeaderIconButtonStyle}"
                                    Width="24"
                                    Height="24"
                                    Click="MinimizeButton_OnClick"
                                    ToolTip="最小化到托盘">
                                <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                            <Button Style="{StaticResource HeaderIconButtonStyle}"
                                    Width="24"
                                    Height="24"
                                    Command="{Binding TogglePanelCollapseCommand}"
                                    ToolTip="{Binding PanelCollapseToolTip}">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#xE70D;"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                    <Setter Property="Text" Value="&#xE70E;"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="MainModulesScrollViewer"
                              Grid.Row="1"
                              Margin="12,0,12,10"
                              ClipToBounds="True"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="None"
                              MouseWheel="OnScrollViewerPreviewMouseWheel">
                    <Grid x:Name="MainModulesGrid"
                          ClipToBounds="False">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="TimeWeatherModule"
                                Grid.Row="0"
                                Margin="0,0,0,6"
                                ClipToBounds="True">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ModuleCardStyle}">
                                    <Setter Property="Padding" Value="14,10"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                            <Setter Property="Padding" Value="10,6"/>
                                            <Setter Property="Margin" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition>
                                        <ColumnDefinition.Style>
                                            <Style TargetType="ColumnDefinition">
                                                <Setter Property="Width" Value="142"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                        <Setter Property="Width" Value="150"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ColumnDefinition.Style>
                                    </ColumnDefinition>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="ClockHotspot"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        Cursor="Hand"
                                        Padding="0,2"
                                        MouseLeftButtonDown="ClockHotspot_OnMouseLeftButtonDown">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ClockTimeText}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=43}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                            <Setter Property="FontSize" Value="30"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding ClockDateText}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                                    <Setter Property="FontSize" Value="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=11}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                            <Setter Property="FontSize" Value="10"/>
                                                            <Setter Property="Margin" Value="0,1,0,0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding ClockLunarText}"
                                                   Visibility="{Binding ClockLunarText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                                    <Setter Property="FontSize" Value="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=11}"/>
                                                    <Setter Property="Margin" Value="0,5,0,0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                            <Setter Property="FontSize" Value="9"/>
                                                            <Setter Property="Margin" Value="0,2,0,0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Column="1"
                                      Grid.Row="0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,0,0,0"
                                      ClipToBounds="True">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="58"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="4,0,2,0"
                                              Visibility="{Binding HasWeatherData, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Width" Value="48"/>
                                                    <Setter Property="Height" Value="48"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                            <Setter Property="Width" Value="32"/>
                                                            <Setter Property="Height" Value="32"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Image Source="{Binding WeatherIconImage}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Visibility="{Binding UseWeatherIconImage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Width" Value="48"/>
                                                        <Setter Property="Height" Value="48"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                                <Setter Property="Width" Value="32"/>
                                                                <Setter Property="Height" Value="32"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock Text="{Binding WeatherIconGlyph}"
                                                       FontFamily="{StaticResource QWeatherIconsFont}"
                                                       Foreground="{Binding WeatherIconForeground}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding UseWeatherIconImage, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontSize" Value="42"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                                <Setter Property="FontSize" Value="28"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding WeatherTemperature}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       HorizontalAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontSize" Value="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=24}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                                <Setter Property="FontSize" Value="18"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding WeatherDescription}"
                                                       HorizontalAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                                        <Setter Property="FontSize" Value="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=12}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                                <Setter Property="FontSize" Value="10"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding WeatherDetailLine}"
                                               HorizontalAlignment="Right"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                                <Setter Property="FontSize" Value="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=11}"/>
                                                <Setter Property="Margin" Value="0,6,0,0"/>
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <StackPanel Grid.Row="2"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                Margin="0,6,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                        <Setter Property="Margin" Value="0,3,0,0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="&#xE707;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding WeatherCity}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                                    <Setter Property="FontSize" Value="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=11}"/>
                                                    <Setter Property="MaxWidth" Value="70"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                            <Setter Property="FontSize" Value="9"/>
                                                            <Setter Property="MaxWidth" Value="52"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text=" | "
                                                   Style="{StaticResource SecondaryTextStyle}"
                                                   FontSize="11"
                                                   Margin="7,0"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding WeatherRangeLine, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding WeatherRangeLine}"
                                                   VerticalAlignment="Center"
                                                   TextAlignment="Right"
                                                   Visibility="{Binding WeatherRangeLine, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                                    <Setter Property="FontSize" Value="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=11}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPanelCollapsed}" Value="True">
                                                            <Setter Property="FontSize" Value="9"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,8,0,0"
                                        Padding="8,5"
                                        CornerRadius="8"
                                        Background="#12FFFFFF">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsPanelCollapsed}" Value="True"/>
                                                        <Condition Binding="{Binding HasCollapsedPanelTodo}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0"
                                                 Width="7"
                                                 Height="7"
                                                 Fill="{Binding CollapsedPanelTodo.Priority, Converter={StaticResource TodoPriorityBrush}}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,7,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CollapsedPanelTodo.Title}"
                                                   Style="{StaticResource BodyTextStyle}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding CollapsedPanelTodoDueText}"
                                                   FontSize="10"
                                                   Foreground="#5DB7FF"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   Visibility="{Binding CollapsedPanelTodoDueText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>

                                <Popup PlacementTarget="{Binding ElementName=WindowContainer}"
                                       Placement="Left"
                                       AllowsTransparency="True"
                                       StaysOpen="True"
                                       DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                       IsOpen="{Binding IsCalendarPopupOpen, Mode=TwoWay}"
                                       HorizontalOffset="-8"
                                       VerticalOffset="62">
                                    <Border Width="360"
                                            Padding="16"
                                            CornerRadius="10"
                                            Background="#E6FFFFFF"
                                            BorderBrush="#E2E8F0"
                                            BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.18" Color="#000000"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding CalendarMonthTitle}"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1E293B"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                                                            Width="32" Height="30"
                                                            Click="PreviousCalendarMonthButton_OnClick"
                                                            ToolTip="上个月">
                                                        <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#64748B"/>
                                                    </Button>
                                                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                                                            Width="32" Height="30"
                                                            Click="NextCalendarMonthButton_OnClick"
                                                            ToolTip="下个月">
                                                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#64748B"/>
                                                    </Button>
                                                    <Button Style="{StaticResource HeaderIconButtonStyle}"
                                                            Width="32" Height="30"
                                                            Margin="4,0,0,0"
                                                            Click="CloseCalendarButton_OnClick"
                                                            ToolTip="关闭">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#64748B"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding CalendarSelectedDetailText}"
                                                       FontSize="13"
                                                       Foreground="#64748B"
                                                       Margin="0,0,0,14"
                                                       TextWrapping="Wrap"/>

                                            <UniformGrid Grid.Row="2" Columns="7" Margin="0,0,0,6">
                                                <TextBlock Text="一" HorizontalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                                <TextBlock Text="二" HorizontalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                                <TextBlock Text="三" HorizontalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                                <TextBlock Text="四" HorizontalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                                <TextBlock Text="五" HorizontalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                                <TextBlock Text="六" HorizontalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                                <TextBlock Text="日" HorizontalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                            </UniformGrid>

                                            <ItemsControl Grid.Row="3" ItemsSource="{Binding CalendarDays}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="7"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Width="43"
                                                                Height="48"
                                                                Margin="1"
                                                                Padding="0"
                                                                Click="CalendarDayButton_OnClick">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                    <Setter Property="Foreground" Value="#1E293B"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                                            <Setter Property="Opacity" Value="0.38"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="DayBackground"
                                                                            Background="Transparent"
                                                                            CornerRadius="18">
                                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Day}"
                                                                                       FontSize="16"
                                                                                       Foreground="{TemplateBinding Foreground}"
                                                                                       HorizontalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding LunarText}"
                                                                                       FontSize="11"
                                                                                       Foreground="#64748B"
                                                                                       HorizontalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="DayBackground" Property="Background" Value="#1A3B82F6"/>
                                                                        </Trigger>
                                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                            <Setter TargetName="DayBackground" Property="BorderBrush" Value="#3B82F6"/>
                                                                            <Setter TargetName="DayBackground" Property="BorderThickness" Value="1"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter TargetName="DayBackground" Property="Background" Value="#1A3B82F6"/>
                                                                            <Setter TargetName="DayBackground" Property="BorderBrush" Value="#3B82F6"/>
                                                                            <Setter TargetName="DayBackground" Property="BorderThickness" Value="1"/>
                                                                            <Setter Property="Foreground" Value="#1E293B"/>
                                                                        </DataTrigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>

                        <Border x:Name="HardwareMonitorModule"
                                Grid.Row="1"
                                Style="{StaticResource ModuleCardStyle}"
                                Margin="0,0,0,6"
                                Padding="13,7,13,4"
                                VerticalAlignment="Top"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Grid Width="18" Height="18" Margin="0,0,6,0">
                                        <Border CornerRadius="2.5"
                                                BorderThickness="1.3"
                                                Style="{StaticResource ModuleTitleIconBorderStyle}"/>
                                        <Viewbox Margin="3.2">
                                            <Canvas Width="18" Height="18">
                                                <Path Data="M1.5,9 L5.2,9 L7.2,4.7 L10.4,13.3 L12.7,7.2 L14.2,9 L16.5,9"
                                                      Style="{StaticResource ModuleTitleIconPathStyle}"
                                                      StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Grid>
                                    <TextBlock Text="硬件监视"
                                               Style="{StaticResource ModuleHeaderTextStyle}"
                                               FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=12}"/>
                                </StackPanel>

                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                MinHeight="30"
                                                VerticalAlignment="Top"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SystemCpuUsageText}"
                                                   FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=13}"
                                                   FontWeight="SemiBold"
                                                   LineHeight="16"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding SystemCpuTemperatureText}"
                                                   FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                                   LineHeight="12"
                                                   Margin="0,2,0,0"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                MinHeight="30"
                                                VerticalAlignment="Top"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SystemMemoryUsageText}"
                                                   FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=13}"
                                                   FontWeight="SemiBold"
                                                   LineHeight="16"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="MEM"
                                                   FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                                   LineHeight="12"
                                                   Margin="0,2,0,0"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                MinHeight="30"
                                                VerticalAlignment="Top"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SystemGpuUsageText}"
                                                   FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=13}"
                                                   FontWeight="SemiBold"
                                                   LineHeight="16"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding SystemGpuTemperatureText}"
                                                   FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                                   LineHeight="12"
                                                   Margin="0,2,0,0"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="2"
                                        Margin="0,4,0,0"
                                        Padding="0,3,0,0"
                                        VerticalAlignment="Top"
                                        BorderThickness="0,1,0,0"
                                        BorderBrush="{DynamicResource GlassHighlightBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="接收RX"
                                                       FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                                       FontWeight="SemiBold"
                                                       LineHeight="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Text="{Binding SystemNetworkReceivedText}"
                                                       FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10.5}"
                                                       FontWeight="SemiBold"
                                                       LineHeight="12"
                                                       Margin="6,0,0,0"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="发送TX"
                                                       FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                                       FontWeight="SemiBold"
                                                       LineHeight="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Text="{Binding SystemNetworkSentText}"
                                                       FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10.5}"
                                                       FontWeight="SemiBold"
                                                       LineHeight="12"
                                                       Margin="6,0,0,0"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="ShortcutsModule"
                                Grid.Row="2"
                                Style="{StaticResource ModuleCardStyle}"
                                Margin="0,0,0,6"
                                Padding="12,10"
                                ClipToBounds="True"
                                AllowDrop="True"
                                PreviewDragEnter="ShortcutModule_OnPreviewDragEnter"
                                PreviewDragOver="ShortcutModule_OnPreviewDragOver"
                                PreviewDragLeave="ShortcutModule_OnPreviewDragLeave"
                                PreviewDrop="ShortcutModule_OnPreviewDrop">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <UniformGrid Width="18" Height="18" Rows="2" Columns="2" Margin="0,0,6,0">
                                            <Border Width="7" Height="7" CornerRadius="1.5" Style="{StaticResource ModuleTitleIconFillStyle}"/>
                                            <Border Width="7" Height="7" CornerRadius="1.5" Style="{StaticResource ModuleTitleIconFillStyle}"/>
                                            <Border Width="7" Height="7" CornerRadius="1.5" Style="{StaticResource ModuleTitleIconFillStyle}"/>
                                            <Border Width="7" Height="7" CornerRadius="1.5" Style="{StaticResource ModuleTitleIconFillStyle}"/>
                                        </UniformGrid>
                                        <TextBlock Text="快捷方式" Style="{StaticResource ModuleHeaderTextStyle}" FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=12}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="拖动图标调整顺序"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   Visibility="{Binding IsEditingShortcuts, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Button FontSize="10"
                                                Command="{Binding ToggleShortcutEditCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                    <Setter Property="Content" Value="编辑"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditingShortcuts}" Value="True">
                                                            <Setter Property="Content" Value="完成"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <ScrollViewer x:Name="ShortcutScrollViewer"
                                              Grid.Row="1"
                                              Margin="0,8,0,0"
                                              VerticalScrollBarVisibility="Hidden"
                                              HorizontalScrollBarVisibility="Disabled"
                                              PanningMode="None"
                                              ClipToBounds="True"
                                              PreviewMouseWheel="OnScrollViewerPreviewMouseWheel"
                                              PreviewMouseLeftButtonDown="ScrollViewer_OnPreviewMouseLeftButtonDown"
                                              PreviewMouseMove="ScrollViewer_OnPreviewMouseMove"
                                              PreviewMouseLeftButtonUp="ScrollViewer_OnPreviewMouseLeftButtonUp"
                                              MouseLeave="ScrollViewer_OnMouseLeave">
                                <ItemsControl ItemsSource="{Binding ShortcutDisplayEntries}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Top">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3" VerticalAlignment="Top"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="VerticalAlignment" Value="Top"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.Resources>
                                        <DataTemplate DataType="{x:Type models:ShortcutItem}">
                                            <Grid Height="72"
                                                  Margin="0,0,0,6"
                                                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  AllowDrop="True"
                                                  PreviewMouseLeftButtonDown="ShortcutItem_OnPreviewMouseLeftButtonDown"
                                                  PreviewMouseLeftButtonUp="ShortcutItem_OnPreviewMouseLeftButtonUp"
                                                  PreviewMouseMove="ShortcutItem_OnPreviewMouseMove"
                                                  DragEnter="ShortcutItem_OnDragEnter"
                                                  DragOver="ShortcutItem_OnDragOver"
                                                  DragLeave="ShortcutItem_OnDragLeave"
                                                  Drop="ShortcutItem_OnDrop">
                                                <Grid.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="上移"
                                                                  Command="{Binding PlacementTarget.Tag.MoveShortcutUpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding}"/>
                                                        <MenuItem Header="下移"
                                                                  Command="{Binding PlacementTarget.Tag.MoveShortcutDownCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding}"/>
                                                        <Separator/>
                                                        <MenuItem Header="移到最前"
                                                                  Command="{Binding PlacementTarget.Tag.MoveShortcutToFirstCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding}"/>
                                                        <MenuItem Header="移到最后"
                                                                  Command="{Binding PlacementTarget.Tag.MoveShortcutToLastCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                                <StackPanel Width="82"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Top">
                                                    <Button Width="47"
                                                            Height="47"
                                                            HorizontalAlignment="Center"
                                                            Command="{Binding DataContext.LaunchShortcutCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{Binding Name}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource ShortcutIconButtonStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.IsEditingShortcuts, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                        <Setter Property="IsEnabled" Value="False"/>
                                                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Border Width="47"
                                                                Height="47"
                                                                CornerRadius="9"
                                                                Background="{DynamicResource GlassHighlightBrush}">
                                                            <Grid>
                                                                <Image Width="35"
                                                                       Height="35"
                                                                       Stretch="Uniform"
                                                                       Source="{Binding IconPath, Converter={StaticResource ShortcutIconConverter}}"
                                                                       Visibility="{Binding IconPath, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="23"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                                           Visibility="{Binding IconPath, Converter={StaticResource StringNotEmptyToVisibilityConverter}, ConverterParameter=Invert}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="&#xE8A5;"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Type}" Value="Application">
                                                                                    <Setter Property="Text" Value="&#xE756;"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Type}" Value="Folder">
                                                                                    <Setter Property="Text" Value="&#xE8B7;"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                    </Button>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="{Binding DataContext.FontScale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"
                                                               MaxWidth="76"
                                                               IsHitTestVisible="False"
                                                               Cursor="Arrow"/>
                                                </StackPanel>

                                                <Button Style="{StaticResource GhostButtonStyle}"
                                                        Width="16"
                                                        Height="16"
                                                        Padding="0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Command="{Binding DataContext.DeleteShortcutCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding DataContext.IsEditingShortcuts, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="&#xE711;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="8"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>

                                        <DataTemplate DataType="{x:Type helpers:AddShortcutPlaceholder}">
                                            <Grid Height="72" Margin="0,0,0,6">
                                                <StackPanel Width="82"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Top">
                                                    <Button x:Name="AddShortcutButton"
                                                            Style="{StaticResource ShortcutIconButtonStyle}"
                                                            Width="47"
                                                            Height="47"
                                                            HorizontalAlignment="Center"
                                                            Command="{Binding DataContext.OpenShortcutAddMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Border Width="47"
                                                                Height="47"
                                                                CornerRadius="9"
                                                                BorderBrush="{DynamicResource GlassHighlightBrush}"
                                                                BorderThickness="1.2"
                                                                Background="{DynamicResource ModuleBackgroundBrush}">
                                                            <TextBlock Text="&#xE710;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="20"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Button>
                                                    <TextBlock Text="添加"
                                                               FontSize="{Binding DataContext.FontScale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"
                                                               MaxWidth="76"
                                                               IsHitTestVisible="False"/>
                                                </StackPanel>

                                                <Popup PlacementTarget="{Binding ElementName=AddShortcutButton}"
                                                       Placement="Right"
                                                       StaysOpen="False"
                                                       AllowsTransparency="True"
                                                       PopupAnimation="Fade"
                                                       HorizontalOffset="6"
                                                       VerticalOffset="-4"
                                                       Closed="ShortcutAddPopup_OnClosed"
                                                       IsOpen="{Binding DataContext.IsShortcutAddMenuOpen, RelativeSource={RelativeSource AncestorType=Window}}">
                                                    <Border MinWidth="132"
                                                            Padding="4"
                                                            CornerRadius="8"
                                                            Background="{DynamicResource ModuleBackgroundBrush}"
                                                            BorderBrush="{DynamicResource GlassHighlightBrush}"
                                                            BorderThickness="1">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.35" Color="#000000"/>
                                                        </Border.Effect>
                                                        <StackPanel>
                                                            <StackPanel Visibility="{Binding DataContext.IsSystemAppMenuOpen, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                                <Button Style="{StaticResource GhostButtonStyle}"
                                                                        HorizontalContentAlignment="Left"
                                                                        Padding="10,6"
                                                                        FontSize="11"
                                                                        Command="{Binding DataContext.AddShortcutFromFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        Content="文件或程序"/>
                                                                <Button Style="{StaticResource GhostButtonStyle}"
                                                                        HorizontalContentAlignment="Left"
                                                                        Padding="10,6"
                                                                        FontSize="11"
                                                                        Command="{Binding DataContext.AddShortcutFromFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        Content="文件夹"/>
                                                                <Button Style="{StaticResource GhostButtonStyle}"
                                                                        HorizontalContentAlignment="Left"
                                                                        Padding="10,6"
                                                                        FontSize="11"
                                                                        Command="{Binding DataContext.OpenSystemAppMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        Content="系统应用"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.IsSharedSizeScope="True"
                                                                        Visibility="{Binding DataContext.IsSystemAppMenuOpen, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <Button Style="{StaticResource GhostButtonStyle}"
                                                                        HorizontalContentAlignment="Stretch"
                                                                        Padding="8,5,10,5"
                                                                        FontSize="11"
                                                                        Command="{Binding DataContext.BackToShortcutAddMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="auto" SharedSizeGroup="SysAppIcon"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0" Width="24" Height="20"/>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="返回"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="8,0,0,0"/>
                                                                    </Grid>
                                                                </Button>
                                                                <ItemsControl ItemsSource="{Binding DataContext.SystemApps, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              MaxHeight="220">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button Style="{StaticResource GhostButtonStyle}"
                                                                                    HorizontalContentAlignment="Stretch"
                                                                                    Padding="8,5,10,5"
                                                                                    FontSize="11"
                                                                                    Command="{Binding DataContext.AddShortcutFromSystemAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                    CommandParameter="{Binding}">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="auto" SharedSizeGroup="SysAppIcon"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <Border Grid.Column="0"
                                                                                            Width="24"
                                                                                            Height="20"
                                                                                            HorizontalAlignment="Center">
                                                                                        <Image Width="18"
                                                                                               Height="18"
                                                                                               Stretch="Uniform"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center"
                                                                                               RenderOptions.BitmapScalingMode="HighQuality"
                                                                                               Source="{Binding BundledIconFileName, Converter={StaticResource BundledIconPathConverter}}"/>
                                                                                    </Border>
                                                                                    <TextBlock Grid.Column="1"
                                                                                               Text="{Binding Name}"
                                                                                               VerticalAlignment="Center"
                                                                                               Margin="8,0,0,0"/>
                                                                                </Grid>
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.Resources>
                                </ItemsControl>
                                </ScrollViewer>

                                <TextBlock Grid.Row="1"
                                           Text="暂无快捷方式，可点击添加，或直接拖入应用、文件、文件夹"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Margin="24,8"
                                           IsHitTestVisible="False"
                                           Visibility="{Binding HasShortcuts, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                                <Border Grid.RowSpan="2"
                                        CornerRadius="10"
                                        Background="{DynamicResource GlassHighlightBrush}"
                                        BorderBrush="{DynamicResource PrimaryTextBrush}"
                                        BorderThickness="1.2"
                                        Opacity="0.88"
                                        IsHitTestVisible="False"
                                        Visibility="{Binding IsShortcutDropTargetActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="松开以添加快捷方式"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=12}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <Border x:Name="TodosModule"
                                Grid.Row="3"
                                Style="{StaticResource ModuleCardStyle}"
                                Margin="0"
                                Padding="14,12"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Viewbox Width="19" Height="19" Margin="0,0,6,0">
                                            <Canvas Width="20" Height="20">
                                                <Path Data="M3,3.5 L17,3.5 L17,16.5 L3,16.5 Z"
                                                      Style="{StaticResource ModuleTitleIconPathStyle}"
                                                      StrokeThickness="1.5"
                                                      StrokeLineJoin="Round"
                                                      />
                                                <Path Data="M5,7 L6.2,8.2 L8.3,6.1 M10,7.2 L15,7.2 M5,12 L6.2,13.2 L8.3,11.1 M10,12.2 L15,12.2"
                                                      Style="{StaticResource ModuleTitleIconPathStyle}"
                                                      StrokeThickness="1.6"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="待办事项" Style="{StaticResource ModuleHeaderTextStyle}" FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=13}"/>
                                    </StackPanel>
                                    <Button Style="{StaticResource GhostButtonStyle}"
                                            HorizontalAlignment="Right"
                                            Content="+"
                                            FontSize="16"
                                            Padding="6,0"
                                            Command="{Binding AddTodoCommand}"/>
                                </Grid>

                                <ScrollViewer x:Name="TodoScrollViewer"
                                              Grid.Row="1"
                                              VerticalScrollBarVisibility="Hidden"
                                              HorizontalScrollBarVisibility="Disabled"
                                              PanningMode="None"
                                              PreviewMouseWheel="OnScrollViewerPreviewMouseWheel"
                                              PreviewMouseLeftButtonDown="ScrollViewer_OnPreviewMouseLeftButtonDown"
                                              PreviewMouseMove="ScrollViewer_OnPreviewMouseMove"
                                              PreviewMouseLeftButtonUp="ScrollViewer_OnPreviewMouseLeftButtonUp"
                                              MouseLeave="ScrollViewer_OnMouseLeave">
                                    <ItemsControl ItemsSource="{Binding Todos}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <controls:TodoSwipeRow Margin="0,0,0,2"
                                                                   DeleteCommand="{Binding DataContext.DeleteTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   EditCommand="{Binding DataContext.EditTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Grid.Column="0" Width="6" Height="6"
                                                             Fill="{Binding Priority, Converter={StaticResource TodoPriorityBrush}}"
                                                             VerticalAlignment="Center"
                                                             Margin="5,0,7,0"/>
                                                    <Ellipse Grid.Column="1"
                                                             Tag="TodoCheck"
                                                             Width="17" Height="17"
                                                             Stroke="{DynamicResource PrimaryTextBrush}"
                                                             StrokeThickness="2"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center"
                                                             Cursor="Hand">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="Transparent"/>
                                                                <Setter Property="Stroke" Value="{DynamicResource PrimaryTextBrush}"/>
                                                                <Setter Property="StrokeThickness" Value="2"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                                        <Setter Property="Stroke" Value="{DynamicResource SuccessBrush}"/>
                                                                        <Setter Property="StrokeThickness" Value="1.5"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                        <Ellipse.InputBindings>
                                                            <MouseBinding Gesture="LeftClick"
                                                                          Command="{Binding DataContext.ToggleTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Ellipse.InputBindings>
                                                    </Ellipse>
                                                    <Grid Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="{Binding DataContext.FontScale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=11}"
                                                                   TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                                                    <Setter Property="FontSize" Value="{Binding DataContext.FontScale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=11}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                            <Setter Property="Foreground" Value="#D5CCEA"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Rectangle Height="2"
                                                                   RadiusX="1"
                                                                   RadiusY="1"
                                                                   Fill="#BFAFE0"
                                                                   Opacity="0.9"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Stretch"
                                                                   Visibility="{Binding IsCompleted, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </Grid>
                                                    <TextBlock Grid.Column="3"
                                                               VerticalAlignment="Center"
                                                               FontSize="{Binding DataContext.FontScale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=11}"
                                                               Margin="8,0,4,0">
                                                        <TextBlock.Text>
                                                            <Binding Path="." Converter="{StaticResource TodoDueTextConverter}"/>
                                                        </TextBlock.Text>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#5DB7FF"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Value="True">
                                                                        <DataTrigger.Binding>
                                                                            <Binding Path="." Converter="{StaticResource TodoDueIsTodayConverter}"/>
                                                                        </DataTrigger.Binding>
                                                                        <Setter Property="Foreground" Value="#FF7E45"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </controls:TodoSwipeRow>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border x:Name="QuickNotesModule"
                                Grid.Row="4"
                                Style="{StaticResource ModuleCardStyle}"
                                Margin="0"
                                Padding="14,12"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Viewbox Width="18" Height="18" Margin="0,0,6,0">
                                            <Canvas Width="20" Height="20">
                                                <Path Data="M4,3.5 L16,3.5 Q17,3.5 17,4.5 L17,15.5 Q17,16.5 16,16.5 L4,16.5 Q3,16.5 3,15.5 L3,4.5 Q3,3.5 4,3.5 Z"
                                                      Style="{StaticResource ModuleTitleIconPathStyle}"
                                                      StrokeThickness="1.5"
                                                      StrokeLineJoin="Round"/>
                                                <Path Data="M6,7 L14,7 M6,10 L14,10 M6,13 L11,13"
                                                      Style="{StaticResource ModuleTitleIconPathStyle}"
                                                      StrokeThickness="1.6"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="快速便签"
                                                   Style="{StaticResource ModuleHeaderTextStyle}"
                                                   FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=13}"/>
                                    </StackPanel>
                                    <Button Style="{StaticResource GhostButtonStyle}"
                                            HorizontalAlignment="Right"
                                            Content="+ 新建"
                                            FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                            Padding="6,0"
                                            Command="{Binding NewQuickNoteCommand}"/>
                                </Grid>

                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Hidden"
                                              HorizontalScrollBarVisibility="Disabled"
                                              PanningMode="None"
                                              PreviewMouseWheel="OnScrollViewerPreviewMouseWheel"
                                              PreviewMouseLeftButtonDown="ScrollViewer_OnPreviewMouseLeftButtonDown"
                                              PreviewMouseMove="ScrollViewer_OnPreviewMouseMove"
                                              PreviewMouseLeftButtonUp="ScrollViewer_OnPreviewMouseLeftButtonUp"
                                              MouseLeave="ScrollViewer_OnMouseLeave">
                                    <ItemsControl ItemsSource="{Binding QuickNotes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource GlassHighlightBrush}"
                                                        CornerRadius="8"
                                                        Padding="8,6"
                                                        Margin="0,0,0,6"
                                                        Cursor="Hand"
                                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                                    <Border.InputBindings>
                                                        <MouseBinding Gesture="LeftClick"
                                                                      Command="{Binding DataContext.EditQuickNoteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <Border.ContextMenu>
                                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                            <MenuItem Header="编辑"
                                                                      Command="{Binding PlacementTarget.Tag.EditQuickNoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}"/>
                                                            <MenuItem Header="复制内容"
                                                                      Command="{Binding PlacementTarget.Tag.CopyQuickNoteContentCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}"/>
                                                            <MenuItem Command="{Binding PlacementTarget.Tag.ToggleQuickNotePinnedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}">
                                                                <MenuItem.Style>
                                                                    <Style TargetType="MenuItem">
                                                                        <Setter Property="Header" Value="置顶"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                                <Setter Property="Header" Value="取消置顶"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </MenuItem.Style>
                                                            </MenuItem>
                                                            <Separator/>
                                                            <MenuItem Header="删除"
                                                                      Command="{Binding PlacementTarget.Tag.DeleteQuickNoteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding}"/>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid Grid.Row="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0"
                                                                        Orientation="Horizontal"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="&#xE840;"
                                                                           FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="10"
                                                                           Margin="0,0,5,0"
                                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                                           Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                <TextBlock Text="{Binding DisplayTitle}"
                                                                           FontSize="{Binding DataContext.FontScale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=11}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding UpdatedAtText}"
                                                                       FontSize="{Binding DataContext.FontScale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=9}"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       Margin="8,0,0,0"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding Summary}"
                                                                   FontSize="{Binding DataContext.FontScale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,3,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock Grid.Row="1"
                                           Text="暂无便签，点击新建快速记录"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Margin="24,8"
                                           IsHitTestVisible="False"
                                           Visibility="{Binding HasQuickNotes, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Border>

                        <Border x:Name="QuickTextModule"
                                Grid.Row="5"
                                Style="{StaticResource ModuleCardStyle}"
                                Margin="0"
                                Padding="14,12"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,7">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Viewbox Width="18" Height="18" Margin="0,0,6,0">
                                            <Canvas Width="20" Height="20">
                                                <Path Data="M5,4 L15,4 L15,16 L5,16 Z M7,7 L13,7 M7,10 L13,10 M7,13 L11,13"
                                                      Style="{StaticResource ModuleTitleIconPathStyle}"
                                                      StrokeThickness="1.5"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="快捷文本"
                                                   Style="{StaticResource ModuleHeaderTextStyle}"
                                                   FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=13}"/>
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right"
                                            Content="+"
                                            FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=14}"
                                            Padding="7,0"
                                            Command="{Binding NewTextSnippetCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsQuickTextSnippetsSelected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,0,0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Height="24"
                                            Margin="0,0,4,0"
                                            Command="{Binding SelectQuickTextModeCommand}"
                                            CommandParameter="History"
                                            Content="历史">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsQuickTextHistorySelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource GlassHighlightBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Height="24"
                                            Margin="4,0,0,0"
                                            Command="{Binding SelectQuickTextModeCommand}"
                                            CommandParameter="Snippets"
                                            Content="常用">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsQuickTextSnippetsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource GlassHighlightBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  PanningMode="None"
                                                  PreviewMouseWheel="OnScrollViewerPreviewMouseWheel"
                                                  PreviewMouseLeftButtonDown="ScrollViewer_OnPreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="ScrollViewer_OnPreviewMouseMove"
                                                  PreviewMouseLeftButtonUp="ScrollViewer_OnPreviewMouseLeftButtonUp"
                                                  MouseLeave="ScrollViewer_OnMouseLeave"
                                                  Visibility="{Binding IsQuickTextHistorySelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ItemsControl ItemsSource="{Binding ClipboardHistory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource GlassHighlightBrush}"
                                                            CornerRadius="8"
                                                            Padding="8,6"
                                                            Margin="0,0,0,6"
                                                            Cursor="Hand"
                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Border.InputBindings>
                                                            <MouseBinding Gesture="LeftClick"
                                                                          Command="{Binding DataContext.CopyClipboardHistoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Border.ContextMenu>
                                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                                <MenuItem Header="复制"
                                                                          Command="{Binding PlacementTarget.Tag.CopyClipboardHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding}"/>
                                                                <MenuItem Header="收藏为常用短语"
                                                                          Command="{Binding PlacementTarget.Tag.FavoriteClipboardHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding}"/>
                                                                <MenuItem Header="删除"
                                                                          Command="{Binding PlacementTarget.Tag.DeleteClipboardHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding}"/>
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <TextBlock Text="{Binding Summary}"
                                                                   FontSize="{Binding DataContext.FontScale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  PanningMode="None"
                                                  PreviewMouseWheel="OnScrollViewerPreviewMouseWheel"
                                                  PreviewMouseLeftButtonDown="ScrollViewer_OnPreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="ScrollViewer_OnPreviewMouseMove"
                                                  PreviewMouseLeftButtonUp="ScrollViewer_OnPreviewMouseLeftButtonUp"
                                                  MouseLeave="ScrollViewer_OnMouseLeave"
                                                  Visibility="{Binding IsQuickTextSnippetsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ItemsControl ItemsSource="{Binding TextSnippets}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource GlassHighlightBrush}"
                                                            CornerRadius="8"
                                                            Padding="8,6"
                                                            Margin="0,0,0,6"
                                                            Cursor="Hand"
                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Border.InputBindings>
                                                            <MouseBinding Gesture="LeftClick"
                                                                          Command="{Binding DataContext.CopyTextSnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Border.ContextMenu>
                                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                                <MenuItem Header="复制"
                                                                          Command="{Binding PlacementTarget.Tag.CopyTextSnippetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding}"/>
                                                                <MenuItem Header="编辑"
                                                                          Command="{Binding PlacementTarget.Tag.EditTextSnippetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding}"/>
                                                                <MenuItem Header="删除"
                                                                          Command="{Binding PlacementTarget.Tag.DeleteTextSnippetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                          CommandParameter="{Binding}"/>
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE840;"
                                                                           FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="10"
                                                                           Margin="0,0,5,0"
                                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                                           Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                <TextBlock Text="{Binding DisplayTitle}"
                                                                           FontSize="{Binding DataContext.FontScale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Row="1"
                                                                       Text="{Binding Summary}"
                                                                       FontSize="{Binding DataContext.FontScale, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=9}"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,2,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <TextBlock Text="暂无剪贴板历史"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsQuickTextHistorySelected}" Value="True"/>
                                                            <Condition Binding="{Binding HasClipboardHistory}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="暂无常用短语，可新增或从历史收藏"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsQuickTextSnippetsSelected}" Value="True"/>
                                                            <Condition Binding="{Binding HasTextSnippets}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Grid Grid.Row="3" Margin="0,4,0,0">
                                    <Button Style="{StaticResource GhostButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Content="清空"
                                            FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                            Command="{Binding ClearClipboardHistoryCommand}"
                                            Visibility="{Binding IsQuickTextHistorySelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Style="{StaticResource GhostButtonStyle}"
                                            HorizontalAlignment="Right"
                                            Content="管理"
                                            FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                            Command="{Binding OpenQuickTextManagerCommand}"
                                            Visibility="{Binding IsQuickTextSnippetsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <Button Style="{StaticResource GhostButtonStyle}"
                                            HorizontalAlignment="Right"
                                            Content="管理"
                                            FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=10}"
                                            Command="{Binding OpenQuickTextManagerCommand}"
                                            Visibility="{Binding IsQuickTextHistorySelected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="EmptyModulesMessage"
                                   Grid.RowSpan="6"
                                   Text="暂无启用模块，请在设置中开启"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="{Binding FontScale, Converter={StaticResource ScaledFontSizeConverter}, ConverterParameter=12}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="20"
                                   Visibility="Collapsed"/>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
