<Window x:Class="UniDesk.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:UniDesk.Helpers"
        Title="设置"
        SizeToContent="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Closed="SettingsWindow_OnClosed"
        KeyDown="SettingsWindow_OnKeyDown"
        PreviewMouseLeftButtonDown="Window_OnPreviewMouseLeftButtonDown"
        PreviewMouseMove="Window_OnPreviewMouseMove"
        PreviewMouseLeftButtonUp="Window_OnPreviewMouseLeftButtonUp"
        MouseLeave="Window_OnMouseLeave">

    <Window.Resources>
        <helpers:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <SolidColorBrush x:Key="DlgBackground" Color="#E6FFFFFF"/>
        <SolidColorBrush x:Key="DlgTextPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="DlgTextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="DlgBorder" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="DlgInputBackground" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="DlgAccent" Color="#3B82F6"/>
        <SolidColorBrush x:Key="DlgAccentSoft" Color="#1A3B82F6"/>

        <Style x:Key="DlgLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DlgSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="DlgChipButton" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextSecondary}"/>
            <Setter Property="Background" Value="{StaticResource DlgInputBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgChipButtonActive" TargetType="Button" BasedOn="{StaticResource DlgChipButton}">
            <Setter Property="Foreground" Value="{StaticResource DlgAccent}"/>
            <Setter Property="Background" Value="{StaticResource DlgAccentSoft}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
        </Style>

        <Style x:Key="DlgGhostButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Background" Value="{StaticResource DlgInputBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgPrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="{StaticResource DlgAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgInlineTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource DlgInputBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource DlgTextPrimary}"/>
        </Style>

        <Style x:Key="DlgSlider" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
        </Style>

        <Style x:Key="DlgToggleRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Border x:Name="DialogRoot"
            Background="{StaticResource DlgBackground}"
            BorderBrush="{StaticResource DlgBorder}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="TitleDragArea"
                    Grid.Row="0"
                    Padding="14,10,12,6"
                    Background="Transparent"
                    Cursor="SizeAll">
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            IsHitTestVisible="False">
                    <Border Width="22" Height="22" CornerRadius="6" Background="{StaticResource DlgAccent}" Margin="0,0,8,0">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="11"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="设置"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource DlgTextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="CloseButton"
                        Grid.Column="1"
                        Width="26" Height="26"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseButton_OnClick">
                    <TextBlock Text="&#xE711;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="11"
                               Foreground="{StaticResource DlgTextSecondary}"/>
                </Button>
                </Grid>
            </Border>

            <ScrollViewer x:Name="ContentScrollViewer"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="14,0,14,4"
                          PreviewMouseLeftButtonDown="ContentScrollViewer_OnPreviewMouseLeftButtonDown"
                          PreviewMouseMove="ContentScrollViewer_OnPreviewMouseMove"
                          PreviewMouseLeftButtonUp="ContentScrollViewer_OnPreviewMouseLeftButtonUp"
                          MouseLeave="ContentScrollViewer_OnMouseLeave">
                <StackPanel>
                    <TextBlock Text="常规设置" Style="{StaticResource DlgSectionTitle}"/>

                    <TextBlock Text="主题设置"
                               Style="{StaticResource DlgLabel}"
                               Margin="0,0,0,6"
                               VerticalAlignment="Top"/>

                    <ItemsControl x:Name="ColorSchemePanel"
                                  ItemsSource="{Binding ColorSchemes}"
                                  Margin="0,0,0,10">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="30" Height="30"
                                        Margin="0,0,8,8"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTip="{Binding DisplayName}"
                                        ToolTipService.InitialShowDelay="200"
                                        ToolTipService.ShowDuration="4000"
                                        Command="{Binding DataContext.SelectColorSchemeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Id}"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid Width="30" Height="30">
                                                <Ellipse Width="24" Height="24"
                                                         Fill="{Binding SwatchBrush}"
                                                         Stroke="{StaticResource DlgBorder}"
                                                         StrokeThickness="1"/>
                                                <Ellipse Width="28" Height="28"
                                                         Stroke="{StaticResource DlgAccent}"
                                                         StrokeThickness="2"
                                                         Visibility="Collapsed"
                                                         x:Name="SelectedRing"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter TargetName="SelectedRing" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="SelectedRing" Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsSelected}" Value="False"/>
                                                        <Condition Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsMouseOver}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter TargetName="SelectedRing" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="SelectedRing" Property="Opacity" Value="0.55"/>
                                                </MultiDataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="窗口透明度" Style="{StaticResource DlgLabel}" Margin="0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding WindowOpacity, StringFormat={}{0:P0}}"
                                   FontSize="11"
                                   Foreground="{StaticResource DlgTextSecondary}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <Slider Style="{StaticResource DlgSlider}"
                            Minimum="0.6" Maximum="1.0"
                            Value="{Binding WindowOpacity, Mode=TwoWay}"
                            TickFrequency="0.05"/>

                    <Grid Margin="0,10,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="52"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="面板宽度" Style="{StaticResource DlgLabel}" Margin="0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PanelWidth, StringFormat={}{0:F0}px}"
                                   FontSize="11"
                                   Foreground="{StaticResource DlgTextSecondary}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <Slider Style="{StaticResource DlgSlider}"
                            Minimum="320" Maximum="520"
                            Value="{Binding PanelWidth, Mode=TwoWay}"
                            TickFrequency="20"/>

                    <TextBlock Text="快捷方式数量"
                               Style="{StaticResource DlgLabel}"
                               Margin="0,10,0,6"
                               VerticalAlignment="Top"/>
                    <WrapPanel x:Name="ShortcutLimitPanel" Margin="0,0,0,14">
                        <Button Style="{StaticResource DlgChipButton}" Content="6" Tag="6"
                                Command="{Binding SelectShortcutLimitCommand}" CommandParameter="6"/>
                        <Button Style="{StaticResource DlgChipButton}" Content="9" Tag="9"
                                Command="{Binding SelectShortcutLimitCommand}" CommandParameter="9"/>
                        <Button Style="{StaticResource DlgChipButton}" Content="12" Tag="12"
                                Command="{Binding SelectShortcutLimitCommand}" CommandParameter="12"/>
                        <Button Style="{StaticResource DlgChipButton}" Content="15" Tag="15"
                                Command="{Binding SelectShortcutLimitCommand}" CommandParameter="15"/>
                        <Button Style="{StaticResource DlgChipButton}" Content="18" Tag="18"
                                Command="{Binding SelectShortcutLimitCommand}" CommandParameter="18"/>
                    </WrapPanel>

                    <TextBlock Text="系统设置" Style="{StaticResource DlgSectionTitle}"/>
                    <Grid Margin="0,0,0,10">
                        <TextBlock Text="待办事项备份还原"
                                   FontSize="12"
                                   Foreground="{StaticResource DlgTextPrimary}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource DlgGhostButton}"
                                    Content="备份"
                                    Padding="12,0"
                                    Margin="0,0,8,0"
                                    Command="{Binding BackupTodosCommand}"/>
                            <Button Style="{StaticResource DlgGhostButton}"
                                    Content="还原"
                                    Padding="12,0"
                                    Command="{Binding RestoreTodosCommand}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Style="{StaticResource DlgToggleRow}">
                        <TextBlock Text="开机自启"
                                   FontSize="12"
                                   Foreground="{StaticResource DlgTextPrimary}"
                                   VerticalAlignment="Center"/>
                        <CheckBox HorizontalAlignment="Right" IsChecked="{Binding StartupEnabled}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Button Style="{StaticResource DlgGhostButton}"
                                Content="恢复默认布局"
                                Padding="10,0"
                                Margin="0,0,8,0"
                                Command="{Binding ResetLayoutCommand}"/>
                        <Button Style="{StaticResource DlgGhostButton}"
                                Content="恢复默认设置"
                                Padding="10,0"
                                Command="{Binding ResetToDefaultsCommand}"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="天气 API 设置" Style="{StaticResource DlgSectionTitle}" VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Padding="8,2"
                                Command="{Binding ToggleWeatherApiEditCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DlgGhostButton}">
                                    <Setter Property="Content" Value="编辑"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditingWeatherApi}" Value="True">
                                            <Setter Property="Content" Value="完成"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                    <TextBlock Text="API Host 与 API Key 需与和风控制台同一项目"
                               FontSize="10"
                               Foreground="{StaticResource DlgTextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="API Host" Style="{StaticResource DlgLabel}"/>
                        <TextBox x:Name="WeatherApiHostTextBox"
                                 Grid.Column="1"
                                 Style="{StaticResource DlgInlineTextBox}"
                                 Text="{Binding WeatherApiHost, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsEditingWeatherApi, Converter={StaticResource InverseBooleanConverter}}"
                                 PreviewMouseLeftButtonDown="WeatherApiTextBox_OnPreviewMouseLeftButtonDown"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="58"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="API Key" Style="{StaticResource DlgLabel}"/>
                        <TextBox x:Name="WeatherApiKeyTextBox"
                                 Grid.Column="1"
                                 Style="{StaticResource DlgInlineTextBox}"
                                 Text="{Binding WeatherApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsEditingWeatherApi, Converter={StaticResource InverseBooleanConverter}}"
                                 PreviewMouseLeftButtonDown="WeatherApiTextBox_OnPreviewMouseLeftButtonDown"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource DlgBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="14,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource DlgGhostButton}"
                            Content="取消"
                            Height="32"
                            MinWidth="80"
                            FontSize="13"
                            Margin="0,0,10,0"
                            Command="{Binding CancelCommand}"/>
                    <Button Style="{StaticResource DlgPrimaryButton}"
                            Content="保存"
                            Command="{Binding SaveCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
