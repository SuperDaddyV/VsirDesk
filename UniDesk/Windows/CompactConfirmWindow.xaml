<Window x:Class="UniDesk.Windows.CompactConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        MinWidth="260"
        MaxWidth="320"
        KeyDown="Window_OnKeyDown">

    <Border Background="#F5FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="12"
            Padding="16,14">
        <StackPanel>
            <TextBlock x:Name="TitleText"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="#1E293B"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="MessageText"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="#64748B"
                       Margin="0,0,0,14"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Content="取消"
                        Width="72"
                        Height="30"
                        Margin="0,0,8,0"
                        FontSize="12"
                        Cursor="Hand"
                        Background="#F8FAFC"
                        Foreground="#64748B"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        Click="CancelButton_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="ConfirmButton"
                        Content="确定"
                        Width="72"
                        Height="30"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Foreground="White"
                        Background="#3B82F6"
                        BorderThickness="0"
                        Click="ConfirmButton_OnClick">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
