<Window x:Class="UniDesk.TodoEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:UniDesk.Helpers"
        xmlns:models="clr-namespace:UniDesk.Models"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="430"
        MinHeight="410"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        KeyDown="TodoEditWindow_OnKeyDown">

    <Window.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
        <helpers:TodoPriorityToBrushConverter x:Key="PriorityBrush"/>
        <helpers:TimeOptionIsSelectedConverter x:Key="TimeSlotSelectedConverter"/>

        <SolidColorBrush x:Key="DlgBackground" Color="#E6FFFFFF"/>
        <SolidColorBrush x:Key="DlgTextPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="DlgTextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="DlgBorder" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="DlgInputBackground" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="DlgAccent" Color="#3B82F6"/>
        <SolidColorBrush x:Key="DlgAccentSoft" Color="#1A3B82F6"/>
        <SolidColorBrush x:Key="DlgPopupBackground" Color="#FFFFFF"/>

        <Style x:Key="DlgLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="DlgPickerButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="{StaticResource DlgInputBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="10,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgPresetButton" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextSecondary}"/>
            <Setter Property="Background" Value="{StaticResource DlgInputBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgPresetButtonActive" TargetType="Button" BasedOn="{StaticResource DlgPresetButton}">
            <Setter Property="Foreground" Value="{StaticResource DlgAccent}"/>
            <Setter Property="Background" Value="{StaticResource DlgAccentSoft}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
        </Style>

        <Style x:Key="DlgPriorityButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="{StaticResource DlgInputBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="8,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgPriorityButtonActive" TargetType="Button" BasedOn="{StaticResource DlgPriorityButton}">
            <Setter Property="Background" Value="{StaticResource DlgAccentSoft}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
        </Style>

        <Style x:Key="DlgGhostButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="{StaticResource DlgInputBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgPrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Background" Value="{StaticResource DlgAccent}"/>
            <Setter Property="Foreground" Value="#0D2744"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgPopupCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource DlgPopupBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgNavIconButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextSecondary}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DlgAccentSoft}"/>
                                <Setter Property="Foreground" Value="{StaticResource DlgAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgWeekdayLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextSecondary}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="DlgDayButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DlgAccentSoft}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DlgAccentSoft}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgTimeChip" TargetType="Button">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="4,0,4,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource DlgTextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource DlgInputBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DlgBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="CalendarDayTemplate" DataType="{x:Type models:CalendarDayItem}">
            <Button Content="{Binding Day}"
                    Tag="{Binding Date}"
                    Click="CalendarDay_OnClick">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource DlgDayButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="{StaticResource DlgAccent}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="DialogRoot"
            Background="{StaticResource DlgBackground}"
            BorderBrush="{StaticResource DlgBorder}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="4"
            MouseLeftButtonDown="DialogRoot_OnMouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="14,12,12,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="24" Height="24" CornerRadius="6" Background="{StaticResource DlgAccent}" Margin="0,0,8,0">
                        <TextBlock Text="+"
                                   Foreground="#0D2744"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-1,0,0"/>
                    </Border>
                    <TextBlock Text="{Binding WindowTitle}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource DlgTextPrimary}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Width="28" Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseButton_OnClick">
                    <TextBlock Text="&#xE711;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="11"
                               Foreground="{StaticResource DlgTextSecondary}"/>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="14,0,14,0">
                    <TextBlock Text="内容" Style="{StaticResource DlgLabel}"/>
                    <Grid Margin="0,0,0,10">
                        <TextBox x:Name="TitleBox"
                                 Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="76"
                                 MaxLength="50"
                                 FontSize="12"
                                 Foreground="{StaticResource DlgTextPrimary}"
                                 Background="{StaticResource DlgInputBackground}"
                                 BorderBrush="{StaticResource DlgBorder}"
                                 BorderThickness="1"
                                 Padding="10,6"
                                 VerticalScrollBarVisibility="Disabled"/>
                        <TextBlock Text="请输入待办事项内容（50字以内）"
                                   IsHitTestVisible="False"
                                   Margin="12,8,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource DlgTextSecondary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Title}" Value=""/>
                                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=TitleBox}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding TitleLength, StringFormat={}{0}/50}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,8,6"
                                   FontSize="10"
                                   Foreground="{StaticResource DlgTextSecondary}"/>
                    </Grid>

                    <TextBlock Text="时间" Style="{StaticResource DlgLabel}"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="DatePickerButton"
                                Grid.Column="0"
                                Style="{StaticResource DlgPickerButton}"
                                Command="{Binding OpenDatePickerCommand}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="&#xE787;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           Foreground="{StaticResource DlgAccent}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DateDisplayText}"
                                           FontSize="12"
                                           Foreground="{StaticResource DlgTextPrimary}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2"
                                           Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="10"
                                           Foreground="{StaticResource DlgTextSecondary}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button x:Name="TimePickerButton"
                                Grid.Column="2"
                                Style="{StaticResource DlgPickerButton}"
                                Command="{Binding OpenTimePickerCommand}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="&#xE823;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           Foreground="{StaticResource DlgAccent}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TimeDisplayText}"
                                           FontSize="12"
                                           Foreground="{StaticResource DlgTextPrimary}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="10"
                                           Foreground="{StaticResource DlgTextSecondary}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Grid>

                    <WrapPanel x:Name="PresetPanel" Margin="0,0,0,10">
                        <Button Style="{StaticResource DlgPresetButton}" Content="今天" Command="{Binding SelectDatePresetCommand}" CommandParameter="Today" Tag="Today"/>
                        <Button Style="{StaticResource DlgPresetButton}" Content="明天" Command="{Binding SelectDatePresetCommand}" CommandParameter="Tomorrow" Tag="Tomorrow"/>
                        <Button Style="{StaticResource DlgPresetButton}" Content="后天" Command="{Binding SelectDatePresetCommand}" CommandParameter="DayAfterTomorrow" Tag="DayAfterTomorrow"/>
                        <Button Style="{StaticResource DlgPresetButton}" Content="本周" Command="{Binding SelectDatePresetCommand}" CommandParameter="ThisWeek" Tag="ThisWeek"/>
                        <Button Style="{StaticResource DlgPresetButton}" Content="自定义" Command="{Binding SelectDatePresetCommand}" CommandParameter="Custom" Tag="Custom"/>
                    </WrapPanel>

                    <TextBlock Text="优先级" Style="{StaticResource DlgLabel}"/>
                    <UniformGrid x:Name="PriorityPanel" Columns="3" Margin="0,0,0,4">
                        <Button Margin="0,0,6,0"
                                Style="{StaticResource DlgPriorityButton}"
                                Command="{Binding SelectPriorityCommand}"
                                CommandParameter="Low"
                                Tag="Low">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#94A3B8" Margin="0,0,6,0"/>
                                <TextBlock Text="低" FontSize="12" Foreground="{StaticResource DlgTextPrimary}"/>
                            </StackPanel>
                        </Button>
                        <Button Margin="0,0,6,0"
                                Style="{StaticResource DlgPriorityButton}"
                                Command="{Binding SelectPriorityCommand}"
                                CommandParameter="Medium"
                                Tag="Medium">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#F59E0B" Margin="0,0,6,0"/>
                                <TextBlock Text="中" FontSize="12" Foreground="{StaticResource DlgTextPrimary}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DlgPriorityButton}"
                                Command="{Binding SelectPriorityCommand}"
                                CommandParameter="High"
                                Tag="High">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#EF4444" Margin="0,0,6,0"/>
                                <TextBlock Text="高" FontSize="12" Foreground="{StaticResource DlgTextPrimary}"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>
            </StackPanel>

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource DlgBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="14,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource DlgGhostButton}"
                            Content="取消"
                            Margin="0,0,10,0"
                            Click="CancelButton_OnClick"/>
                    <Button Style="{StaticResource DlgPrimaryButton}"
                            Content="保存"
                            IsDefault="True"
                            Click="SaveButton_OnClick"/>
                </StackPanel>
            </Border>

            <Popup x:Name="DatePopup"
                   PlacementTarget="{Binding ElementName=DatePickerButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   IsOpen="{Binding IsDatePopupOpen, Mode=TwoWay}"
                   PopupAnimation="Fade"
                   HorizontalOffset="0"
                   VerticalOffset="6">
                <Border Style="{StaticResource DlgPopupCard}" Padding="12" MinWidth="268">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Button Style="{StaticResource DlgNavIconButton}"
                                    HorizontalAlignment="Left"
                                    Content="&#xE76B;"
                                    Click="PrevMonthButton_OnClick"/>
                            <TextBlock x:Name="CalendarMonthText"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource DlgTextPrimary}"/>
                            <Button Style="{StaticResource DlgNavIconButton}"
                                    HorizontalAlignment="Right"
                                    Content="&#xE76C;"
                                    Click="NextMonthButton_OnClick"/>
                        </Grid>
                        <UniformGrid Columns="7" Margin="0,0,0,4">
                            <TextBlock Text="一" Style="{StaticResource DlgWeekdayLabel}"/>
                            <TextBlock Text="二" Style="{StaticResource DlgWeekdayLabel}"/>
                            <TextBlock Text="三" Style="{StaticResource DlgWeekdayLabel}"/>
                            <TextBlock Text="四" Style="{StaticResource DlgWeekdayLabel}"/>
                            <TextBlock Text="五" Style="{StaticResource DlgWeekdayLabel}"/>
                            <TextBlock Text="六" Style="{StaticResource DlgWeekdayLabel}"/>
                            <TextBlock Text="日" Style="{StaticResource DlgWeekdayLabel}"/>
                        </UniformGrid>
                        <ItemsControl x:Name="CalendarDaysHost"
                                      ItemTemplate="{StaticResource CalendarDayTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Popup>

            <Popup x:Name="TimePopup"
                   PlacementTarget="{Binding ElementName=TimePickerButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   IsOpen="{Binding IsTimePopupOpen, Mode=TwoWay}"
                   PopupAnimation="Fade"
                   HorizontalOffset="0"
                   VerticalOffset="6">
                <Border Style="{StaticResource DlgPopupCard}"
                        Padding="10"
                        Width="244">
                    <ScrollViewer x:Name="TimeScrollViewer"
                                  MaxHeight="200"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="TimeScrollViewer_OnPreviewMouseWheel">
                        <ItemsControl ItemsSource="{Binding TimeOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Tag="{Binding}"
                                            Click="TimeChip_OnClick">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource DlgTimeChip}">
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource TimeSlotSelectedConverter}">
                                                                <Binding/>
                                                                <Binding Path="DueDateTime" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Background" Value="{StaticResource DlgAccentSoft}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource DlgAccent}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource DlgAccent}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
